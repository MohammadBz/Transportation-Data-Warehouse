        <mxCell id="fact_monthly" value="&lt;b&gt;Fact_Transportation_Monthly_Snapshot&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Grain&lt;/b&gt;: Agency + Mode + TOS + Month&lt;br&gt;&lt;b&gt;Source&lt;/b&gt;: Monthly Modal Time Series&lt;br&gt;&lt;br&gt;&lt;b&gt;FKs&lt;/b&gt;&lt;br&gt;AgencyKey, ModeKey, ServiceTypeKey&lt;br&gt;DateKey (month), UrbanAreaKey&lt;br&gt;OrganizationTypeKey&lt;br&gt;&lt;br&gt;&lt;b&gt;Measures&lt;/b&gt;&lt;br&gt;VOMS&lt;br&gt;VehicleRevenueMiles / Hours&lt;br&gt;UnlinkedPassengerTrips&lt;br&gt;TotalEvents / Collisions&lt;br&gt;Fatalities / Injuries&lt;br&gt;AssaultsOnTransitWorkers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacing=10;verticalAlign=top;" vertex="1" parent="1">
