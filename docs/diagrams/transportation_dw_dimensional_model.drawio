        <mxCell id="fact_annual" value="&lt;b&gt;Fact_Ridership_Transaction&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Grain&lt;/b&gt;: Agency + Mode + TOS + Year&lt;br&gt;&lt;b&gt;Source&lt;/b&gt;: TS2.1 Current + Archive&lt;br&gt;&lt;br&gt;&lt;b&gt;FKs&lt;/b&gt;&lt;br&gt;AgencyKey, ModeKey, ServiceTypeKey&lt;br&gt;DateKey (year), UrbanAreaKey&lt;br&gt;ReporterTypeKey&lt;br&gt;&lt;br&gt;&lt;b&gt;Measures&lt;/b&gt;&lt;br&gt;UPT, PMT, VRM, VRH, VOMS&lt;br&gt;DRM, Fares&lt;br&gt;OperatingExpense_Total&lt;br&gt;OperatingExpense_VO/VM/NVM/GA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacing=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="650" y="175" width="250" height="330" as="geometry"/>
